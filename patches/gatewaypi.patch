+
+  // GatewayPi tuner tap (see gpSetTunerTap/gpReadTunerSamples above).
+  static constexpr int kGpTunerFifoSize = 16384;
+  juce::AbstractFifo mGpTunerFifo{kGpTunerFifoSize};

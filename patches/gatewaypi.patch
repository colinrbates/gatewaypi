@@ -122,16 +122,20 @@ target_include_directories(NAMixLinux PRIVATE
 # ---------------------------------------------------------------------------
 # Link libraries
 # ---------------------------------------------------------------------------
+# --whole-archive (-force_load on Apple ld) ensures every .o in NamDsp is
+# linked into the plugin, so that static-initialiser registrations (WaveNet,
+# LSTM, etc.) always execute at load time regardless of LTO / --as-needed.
+if(APPLE)
+    target_link_libraries(NAMixLinux PRIVATE NamDsp "-Wl,-force_load,$<TARGET_FILE:NamDsp>")
+else()
+    target_link_libraries(NAMixLinux PRIVATE -Wl,--whole-archive NamDsp -Wl,--no-whole-archive stdc++fs)
+endif()
+
 target_link_libraries(NAMixLinux
     PRIVATE
-        # --whole-archive ensures every .o in NamDsp is linked into the VST3
-        # .so, so that static-initialiser registrations (WaveNet, LSTM, etc.)
-        # always execute at plugin load time regardless of LTO / --as-needed.
-        -Wl,--whole-archive NamDsp -Wl,--no-whole-archive
         NAMixBinaryData
         juce::juce_audio_utils
         juce::juce_opengl
-        stdc++fs
     PUBLIC
         juce::juce_recommended_config_flags
         juce::juce_recommended_lto_flags
@@ -147,3 +151,20 @@ target_compile_options(NAMixLinux PRIVATE
     -Wno-unused-parameter
     $<$<VERSION_LESS:$<CXX_COMPILER_VERSION>,13>:-fpermissive>
 )
+
+# ---------------------------------------------------------------------------
+# GatewayPi appliance layer (kiosk shell, preset bank, MIDI foot control).
+# Enable with -DGATEWAYPI=ON; requires src/gatewaypi/ to be present (copied
+# in by the GatewayPi installer).
+# ---------------------------------------------------------------------------
+option(GATEWAYPI "Build the GatewayPi kiosk appliance layer" OFF)
+if(GATEWAYPI)
+    target_sources(NAMixLinux PRIVATE
+        src/gatewaypi/PresetManager.cpp
+        src/gatewaypi/KioskShell.cpp
+    )
+    target_compile_definitions(NAMixLinux PUBLIC
+        GATEWAYPI=1
+        JUCE_STANDALONE_FILTER_WINDOW_USE_KIOSK_MODE=1
+    )
+endif()

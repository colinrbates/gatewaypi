+    mInputLevel.store(peak, std::memory_order_relaxed);
+    mOutputLevel.store(peak, std::memory_order_relaxed);
+    for (int ch = 1; ch < buffer.getNumChannels(); ++ch)
+      buffer.copyFrom(ch, 0, buffer, 0, 0, buffer.getNumSamples());
+    return;
+  }

--- a/src/PluginProcessor.cpp
+++ b/src/PluginProcessor.cpp
@@ -13,6 +13,10 @@
 #include "PluginProcessor.h"
 #include "PluginEditor.h"
 
+#if GATEWAYPI
+#include "gatewaypi/KioskShell.h"
+#endif
+
 #include "NAM/get_dsp.h"
 
 // Compatibility shims required by the iPlug2-derived LanczosResampler that
@@ -248,6 +252,31 @@ void NAMixAudioProcessor::processBlock(juce::AudioBuffer<float> &buffer,
   if (mIRPending.exchange(false))
     mIR = std::move(mPendingIR);
 
+  // GatewayPi: mute silences the output; bypass passes the dry input through.
+  // Both skip the DSP chain entirely — the model refills its short context in
+  // a few milliseconds when re-engaged.
+  if (mGpMute.load(std::memory_order_relaxed)) {
+    const float *in = buffer.getReadPointer(0);
+    float peak = 0.0f;
+    for (int i = 0; i < buffer.getNumSamples(); ++i)
+      peak = std::max(peak, std::abs(in[i]));
+    mInputLevel.store(peak, std::memory_order_relaxed);
+    mOutputLevel.store(0.0f, std::memory_order_relaxed);
+    buffer.clear();
+    return;
+  }
+  if (mGpBypass.load(std::memory_order_relaxed)) {
+    const float *in = buffer.getReadPointer(0);
+    float peak = 0.0f;
+    for (int i = 0; i < buffer.getNumSamples(); ++i)
+      peak = std::max(peak, std::abs(in[i]));
+    mInputLevel.store(peak, std::memory_order_relaxed);
+    mOutputLevel.store(peak, std::memory_order_relaxed);
+    for (int ch = 1; ch < buffer.getNumChannels(); ++ch)
+      buffer.copyFrom(ch, 0, buffer, 0, 0, buffer.getNumSamples());
+    return;
+  }
+
   // Apply slim size update requested from the message thread.
   if (mSlimDirty.exchange(false, std::memory_order_acq_rel)) {
     const float v = apvts.getRawParameterValue("slim")->load();
@@ -518,7 +547,11 @@ void NAMixAudioProcessor::setStateInformation(const void *data, int sizeInBytes)

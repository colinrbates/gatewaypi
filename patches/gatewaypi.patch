+// ---------------------------------------------------------------------------
+// GatewayPi tuner tap (message thread)
+// ---------------------------------------------------------------------------
+int NAMixAudioProcessor::gpReadTunerSamples(float *dest, int maxSamples) {
+  int s1, b1, s2, b2;
+  mGpTunerFifo.prepareToRead(maxSamples, s1, b1, s2, b2);
+  for (int i = 0; i < b1; ++i)
+    dest[i] = mGpTunerBuf[(size_t)(s1 + i)];
+  for (int i = 0; i < b2; ++i)
+    dest[b1 + i] = mGpTunerBuf[(size_t)(s2 + i)];
+  mGpTunerFifo.finishedRead(b1 + b2);
+  return b1 + b2;
+}
+
+int NAMixAudioProcessor::gpReadOutSamples(float *dest, int maxSamples) {
+  int s1, b1, s2, b2;
+  mGpOutFifo.prepareToRead(maxSamples, s1, b1, s2, b2);
+  for (int i = 0; i < b1; ++i)
+    dest[i] = mGpOutBuf[(size_t)(s1 + i)];
+  for (int i = 0; i < b2; ++i)
+    dest[b1 + i] = mGpOutBuf[(size_t)(s2 + i)];
+  mGpOutFifo.finishedRead(b1 + b2);
+  return b1 + b2;
+}

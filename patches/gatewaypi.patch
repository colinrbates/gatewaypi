+  // GatewayPi appliance hooks: hard bypass (dry signal straight through) and
+  // output mute (silent tuning).  Set from the message thread, read on the
+  // audio thread.
+  void gpSetBypass(bool b) { mGpBypass.store(b, std::memory_order_relaxed); }
+  void gpSetMute(bool m) { mGpMute.store(m, std::memory_order_relaxed); }
+  bool gpGetBypass() const { return mGpBypass.load(std::memory_order_relaxed); }
+  bool gpGetMute() const { return mGpMute.load(std::memory_order_relaxed); }
+
+  // Tuner tap: while enabled, the audio thread pushes raw input samples into
+  // a lock-free FIFO that the tuner UI drains on the message thread.
+  void gpSetTunerTap(bool on) { mGpTunerTap.store(on, std::memory_order_relaxed); }
+  int gpReadTunerSamples(float *dest, int maxSamples);
+
 private:
   void applyDsp(juce::AudioBuffer<float> &buffer);
 
